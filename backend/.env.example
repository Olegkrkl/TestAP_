DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxxx.supabase.co:5432/postgres
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
FRONTEND_URL=http://localhost:5173
# Comma-separated extra CORS origins (optional), e.g. https://testap.vercel.app,https://preview.vercel.app
CORS_ORIGINS=

# Email (Resend) — optional. If empty, email verification still works
# but no real email is sent.
RESEND_API_KEY=
EMAIL_FROM=TestAP <noreply@testap.app>

# Google OAuth (Google Identity Services). Get a Web client_id at
# https://console.cloud.google.com/apis/credentials. Leave empty to disable
# the "Sign in with Google" button.
GOOGLE_CLIENT_ID=

# When true, /auth/login refuses users whose email has not been verified.
REQUIRE_EMAIL_VERIFICATION=false

# Brute-force protection on /auth/login (slowapi)
LOGIN_RATE_LIMIT_PER_MINUTE=10

# Idle-timeout for in-progress sessions (auto-submit if no activity)
SESSION_IDLE_TIMEOUT_MINUTES=360
