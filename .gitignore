# ───────────────────────────── Secrets ─────────────────────────────
# Never commit real credentials. .env.example IS tracked (see negation below).
.env
.env.*
!.env.example
*.pem
*.key

# ──────────────────────────── Python / FastAPI ─────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
.venv/
env/
ENV/
backend/venv/
backend/.venv/

# Test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# ──────────────────────────── Node / React (Vite) ──────────────────
node_modules/
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
dist/
dist-ssr/
*.local

# TypeScript incremental build cache
*.tsbuildinfo

# Logs / debug
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ──────────────────────────── Databases ────────────────────────────
*.sqlite3
*.db

# ──────────────────────────── Editors / IDE ────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ──────────────────────────── OS junk ──────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
